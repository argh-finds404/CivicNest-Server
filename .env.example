# Port number the server should listen on (defaults to 3000)
PORT=3000

# MongoDB Configuration
# You can either provide DB_USER and DB_PASS (will connect to the default Atlas Cluster)
# or provide the full MONGODB_URI/DATABASE_URL directly (recommended for custom hosting).
DB_USER=
DB_PASS=
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

# Stripe Configuration (Payment Gateway)
PAYMENT_GATEWAY_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SSLCommerz Configuration (Local Payment Gateway in Bangladesh)
SSL_STORE_ID=
SSL_STORE_PASSWD=
SSL_IS_LIVE=false

# Client application base URL (used for CORS and redirect URLs)
CLIENT_BASE_URL=http://localhost:5173

# Google Gemini API key (used for CivicBot features)
GEMINI_API_KEY=

# Firebase Admin Service Account Credentials
# Option 1: Stringify your Service Account JSON file and paste it here
# FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "...", ...}
# Option 2: Specify the path to your service account credentials file
# FIREBASE_SERVICE_ACCOUNT_PATH=../beautify-auth-firebase-adminsdk-fbsvc-16ac10c890.json
